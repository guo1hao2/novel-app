{
  "expo": {
    "name": "AI 小说写作",
    "slug": "novel-ai-writer",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "novelaiwriter",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-sqlite"]
  }
}
